{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data from Google Auth",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Room": {
      "title": "Room",
      "description": "A video call room",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hostId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "hostId", "createdAt"]
    },
    "Participant": {
      "title": "Participant",
      "description": "A user currently in a room",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "userId": { "type": "string" },
        "peerId": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "isMuted": { "type": "boolean" },
        "isVideoOff": { "type": "boolean" }
      },
      "required": ["roomId", "userId", "peerId", "joinedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Active meeting rooms"
    },
    "/rooms/{roomId}/participants/{participantId}": {
      "schema": "Participant",
      "description": "Users in a specific room"
    }
  }
}
